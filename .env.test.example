# .env.test — credentials for a DEDICATED Supabase TEST project.
# Copy to .env.test (gitignored) and fill in. NEVER point this at the dev or
# production database: the suite TRUNCATES and re-seeds every table on each run.
#
# Create the test project: Supabase dashboard -> New project (free tier is fine).
# Then Connect -> Session pooler for the DB URL, and Settings -> API for the keys.

# Safety interlock. The suite refuses to touch the database unless this is 1.
# Set it only in a .env.test that points at a throwaway test project.
E2E_TEST_DB=1

# Postgres (Supavisor SESSION pooler URI, port 5432) — used by Sequelize AND by
# the test harness to seed/truncate.
# Copy it verbatim from Supabase -> Connect -> Session pooler.
SUPABASE_DB_URL=postgresql://postgres.<ref>:<pw>@aws-<n>-<region>.pooler.supabase.com:5432/postgres

# Supabase API — the app's browser + server clients. The publishable key
# (sb_publishable_...) is enough: test auth users are seeded straight into
# auth.users over the Postgres connection above, then signed in normally, so
# NO service-role key is required.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<test publishable/anon key>

# The app under test runs here (Playwright starts it on this port).
E2E_PORT=3100
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# The organization the portal + seed use. The seed creates an org with this id
# if unset; set it to that id so the app and the seed agree.
PORTAL_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001

# Lets an owner email into the member area with no membership row (handy for
# member-portal tests). Any address works against the test project.
PORTAL_OWNER_EMAILS=owner@e2e.test

# Bearer secrets for the system endpoints (cron / MCP). Any values are fine on
# the test project; the tests set the matching header.
CRON_SECRET=e2e-cron-secret
MCP_TOKEN=e2e-mcp-token

# Optional — only needed once the paid/checkout and email stories are covered.
# Use Stripe TEST keys and a verified Resend sandbox, or leave unset until then.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
