# Supabase — get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string used by Sequelize (the data ORM) at runtime.
# MUST be the Supavisor SESSION POOLER URI (IPv4, port 5432):
#   postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Get it from Supabase → Connect → Session pooler. The direct host
# (db.<ref>.supabase.co) is IPv6-only and the API host (<ref>.supabase.co)
# is Cloudflare-fronted. Set in Vercel (Production) and locally for dev.
SUPABASE_DB_URL=

# Google OAuth (per-account Contacts + Meet read)
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public origin for OAuth redirects.
# Local dev: http://localhost:3000
# Production: your Vercel URL or custom domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}`. Generate a
# random string and set the same value in Vercel project env vars.
CRON_SECRET=

# MCP server bearer token. AI clients call /api/mcp with
# `Authorization: Bearer ${MCP_TOKEN}`. Generate a long random string
# (e.g. `openssl rand -hex 32`) and set it in Vercel (Production).
MCP_TOKEN=

# Encryption key for per-organization integration secrets (e.g. each
# org's Stripe keys, set in Settings → Integrations). 32 bytes hex:
# `openssl rand -hex 32`. Set it in Vercel (Production); keep it stable
# (rotating it makes existing stored secrets undecryptable).
SECRETS_KEY=
